# --- liaison au ladder (fournis par l'admin) ---
LADDER_URL=https://ladder.kheopsian.com
WORKER_TOKEN=colle-ici-le-token-donne-par-l-admin

# --- auth tr4ker : CHOISIR UN des deux chemins ---

# Chemin A — identifiants (recommandé : re-login automatique tous les ~30 j)
TR4KER_USER=ton_pseudo_tr4ker
TR4KER_PASS=ton_mot_de_passe_tr4ker

# Chemin B — cookie collé (si tu ne veux pas stocker ton mdp / compte 2FA)
#   valeur du cookie TR4KER_session (le JWT). Expire au bout de ~30 j -> à renouveler à la main.
#   le worker accepte la valeur brute OU la forme "TR4KER_session=..."
# TR4KER_COOKIE=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- optionnel ---
# BATCH=150                 # nb de users demandés par lease
# TR4KER_BASE=https://tr4ker.net

# WORKER_LOG=C:\l4dder.log   # (Windows) fichier de log en mode windowless
